# Runtime environment for the API service (development | test | production)
NODE_ENV=development

# TCP port used by the API server
PORT=3002

# Host interface for server binding (0.0.0.0 for container/dev, 127.0.0.1 for local-only)
HOST=0.0.0.0

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://user:password@localhost:5432/vysion_db

# Secret used to sign and verify backend JWT tokens
JWT_SECRET=replace-with-a-strong-random-secret

# JWT token lifetime (examples: 1h, 12h, 7d)
JWT_EXPIRES_IN=7d

# Firebase project identifier for Admin SDK token verification
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase service account client email
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com

# Firebase service account private key (single line with escaped \n)
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# Firebase default storage bucket name
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Allowed browser/app origins for CORS, comma-separated
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# API version label used for diagnostics and metadata
API_VERSION=v1

# API path prefix used by route mounting
API_PREFIX=/api

# Maximum accepted upload size in megabytes
MEDIA_MAX_SIZE_MB=500

# Allowed media MIME types, comma-separated
MEDIA_ALLOWED_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/quicktime

# Upload staging directory for temporary file handling
UPLOAD_DIR=./uploads

# Logging verbosity level (debug | info | warn | error)
LOG_LEVEL=debug
