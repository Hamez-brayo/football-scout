{
  "name": "vysion-analytics",
  "version": "2.0.0",
  "description": "Football Talent Scouting Platform - Mobile-first cross-platform ecosystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "database"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:mobile\"",
    "dev:backend": "cd apps/new-backend && npm run dev",
    "dev:mobile": "cd apps/mobile && npm start",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run build:shared && npm run build:backend",
    "build:shared": "cd packages/shared && npm run build",
    "build:backend": "cd apps/new-backend && npm run build",
    "build:mobile": "cd apps/mobile && npm run build",
    "type-check": "npm run type-check:shared && npm run type-check:backend && npm run type-check:mobile",
    "type-check:shared": "cd packages/shared && npm run type-check",
    "type-check:backend": "cd apps/new-backend && npm run type-check",
    "type-check:mobile": "cd apps/mobile && npm run type-check",
    "db:migrate": "cd database && npm run migrate",
    "db:generate": "cd database && npm run generate",
    "db:studio": "cd database && npm run studio",
    "db:seed": "cd database && npm run seed",
    "test": "echo \"Run tests in individual packages\"",
    "clean": "Remove-Item -Recurse -Force node_modules, apps/*/node_modules, packages/*/node_modules, database/node_modules -ErrorAction SilentlyContinue",
    "fresh": "npm run clean; npm install"
  },
    "keywords": [
      "football",
      "scouting",
      "talent",
      "analytics",
      "react-native",
      "expo",
      "nodejs",
      "prisma",
      "firebase"
    ],
    "author": "Vysion Analytics Team",
    "license": "MIT",
    "repository": {
      "type": "git",
      "url": "git+https://github.com/Hamez-brayo/vysion-analytics.git"
    },
    "bugs": {
      "url": "https://github.com/Hamez-brayo/vysion-analytics/issues"
    },
    "homepage": "https://github.com/Hamez-brayo/vysion-analytics#readme",
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
