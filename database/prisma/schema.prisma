datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

enum UserRole {
  PLAYER
  SCOUT
}

enum RegistrationStatus {
  INCOMPLETE
  JOURNEY_COMPLETED
  COMPLETE
}

enum ExperienceLevel {
  AMATEUR
  ACADEMY
  SEMI_PRO
  PRO
}

enum PreferredFoot {
  LEFT
  RIGHT
  BOTH
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  PENDING
  READY
  FAILED
}

enum DrillType {
  TECHNICAL
  ATHLETIC
}

enum DrillSubmissionStatus {
  PENDING
  VERIFIED
}

model User {
  id                 String             @id @default(cuid())
  userId             String             @unique
  email              String             @unique
  password           String?
  role               UserRole           @default(PLAYER)
  registrationStatus RegistrationStatus @default(INCOMPLETE)

  firstName       String?
  lastName        String?
  fullName        String?
  dateOfBirth     DateTime?
  nationality     String?
  phone           String?
  currentLocation String?
  profilePhoto    String?

  playerProfile    PlayerProfile?
  media            Media[]
  trainingPrograms TrainingProgram[] @relation("ScoutTrainingPrograms")
  drillSubmissions DrillSubmission[] @relation("PlayerDrillSubmissions")
  playerStats      PlayerStat[]      @relation("PlayerStats")

  scoutShortlists  Shortlist[] @relation("ScoutShortlists")
  playerShortlists Shortlist[] @relation("PlayerShortlists")
  scoutViews       PlayerView[] @relation("ScoutPlayerViews")
  playerViews      PlayerView[] @relation("PlayerViews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([nationality])
  @@index([currentLocation])
  @@index([fullName])
  @@index([createdAt])
}

model PlayerProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [userId], onDelete: Cascade)
  primaryPosition  String?
  secondaryPositions String[]      @default([])
  currentClub      String?
  preferredFoot    PreferredFoot?
  experienceLevel  ExperienceLevel?
  isAvailable      Boolean         @default(true)
  bio              String?

  physicalAttributes PhysicalAttributes?
  footballProfile    FootballProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryPosition])
  @@index([currentClub])
  @@index([experienceLevel])
  @@index([isAvailable, primaryPosition])
}

model PhysicalAttributes {
  id              String        @id @default(cuid())
  playerProfileId String        @unique
  playerProfile   PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  heightCm        Float?
  weightKg        Float?
  wingspanCm      Float?
  sprintSpeed     Float?
  staminaScore    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FootballProfile {
  id              String        @id @default(cuid())
  playerProfileId String        @unique
  playerProfile   PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  dominantFoot    PreferredFoot?
  playingStyle    String[]      @default([])
  strongestSkills String[]      @default([])
  weakFootRating  Int?

  achievements Achievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Achievement {
  id               String          @id @default(cuid())
  footballProfileId String
  footballProfile   FootballProfile @relation(fields: [footballProfileId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  date             DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([footballProfileId, date])
}

model Media {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [userId], onDelete: Cascade)
  type        MediaType
  status      MediaStatus @default(PENDING)
  url         String
  thumbnailUrl String?
  mimeType    String
  sizeBytes   Int
  durationSec Int?
  title       String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([type])
  @@index([status])
}

model TrainingProgram {
  id            String   @id @default(cuid())
  title         String
  level         String
  positionFocus String
  description   String?
  createdById   String?
  createdBy     User?    @relation("ScoutTrainingPrograms", fields: [createdById], references: [userId], onDelete: SetNull)

  drills Drill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([positionFocus])
  @@index([createdById])
}

model Drill {
  id                String          @id @default(cuid())
  trainingProgramId String
  trainingProgram   TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  title             String
  type              DrillType
  instructions      String
  videoUrl          String?
  displayOrder      Int             @default(0)

  submissions DrillSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainingProgramId])
  @@index([type])
}

model DrillSubmission {
  id         String                @id @default(cuid())
  playerId   String
  player     User                  @relation("PlayerDrillSubmissions", fields: [playerId], references: [userId], onDelete: Cascade)
  drillId    String
  drill      Drill                 @relation(fields: [drillId], references: [id], onDelete: Cascade)
  videoUrl   String
  status     DrillSubmissionStatus @default(PENDING)
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId, createdAt])
  @@index([drillId, createdAt])
  @@index([status])
}

model MetricType {
  id          String @id @default(cuid())
  key         String @unique
  displayName String
  unit        String?
  description String?

  stats PlayerStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([displayName])
}

model PlayerStat {
  id           String     @id @default(cuid())
  playerId     String
  player       User       @relation("PlayerStats", fields: [playerId], references: [userId], onDelete: Cascade)
  metricTypeId String
  metricType   MetricType @relation(fields: [metricTypeId], references: [id], onDelete: Cascade)
  value        Float
  recordedAt   DateTime
  source       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId, recordedAt])
  @@index([playerId, metricTypeId, recordedAt])
  @@index([metricTypeId, recordedAt])
  @@unique([playerId, metricTypeId, recordedAt])
}

model Shortlist {
  id       String @id @default(cuid())
  scoutId  String
  scout    User   @relation("ScoutShortlists", fields: [scoutId], references: [userId], onDelete: Cascade)
  playerId String
  player   User   @relation("PlayerShortlists", fields: [playerId], references: [userId], onDelete: Cascade)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scoutId, playerId])
  @@index([scoutId, createdAt])
  @@index([playerId, createdAt])
}

model PlayerView {
  id       String @id @default(cuid())
  scoutId  String
  scout    User   @relation("ScoutPlayerViews", fields: [scoutId], references: [userId], onDelete: Cascade)
  playerId String
  player   User   @relation("PlayerViews", fields: [playerId], references: [userId], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@index([scoutId, viewedAt])
  @@index([playerId, viewedAt])
  @@index([scoutId, playerId])
}
